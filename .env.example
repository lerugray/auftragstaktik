# LLM Provider Configuration
LLM_PROVIDER=claude          # claude | openai | openai-compatible
LLM_API_KEY=                 # Your API key (Anthropic, OpenAI, etc.)
LLM_MODEL=claude-sonnet-4-20250514   # Model ID (claude-sonnet-4-20250514, gpt-4o, etc.)
LLM_BASE_URL=                # Only needed for openai-compatible providers

# ACLED (free registration at acleddata.com — uses OAuth, no API key needed)
ACLED_EMAIL=
ACLED_PASSWORD=

# AISStream (free registration at aisstream.io)
AISSTREAM_API_KEY=
